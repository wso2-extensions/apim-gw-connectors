{
  "asyncapi": "2.0.0",
  "info": {
    "title": "${TITLE}",
    "version": "${VERSION}"
  },
  "servers": {
    "production": {
      "url": "${SERVER_URL}",
      "protocol": "${PROTOCOL}"
    }
  },
  "channels": {
    "/*": {
      "subscribe": {
        "summary": "Subscribe to wildcard topic"
      },
      "publish": {
        "summary": "Publish to wildcard topic"
      }
    }
  }
}
