{
  "Kong": {
    "apiTypes": [
      "rest"
    ],
    "gatewayFeatures": {
      "basic": [
        "defaultVersion"
      ],
      "runtime": [
        "cors",
        "transportsHTTP",
        "transportsHTTPS",
        "oauth2",
        "apikey",
        "keyManagerConfig"
      ],
      "resources": [
        "apiLevelRateLimiting",
        "operationLevelRateLimiting",
        "operationSecurity"
      ],
      "localScopes": [],
      "policies": [
        "policies"
      ],
      "monetization": [
        "monetization"
      ],
      "subscriptions": {
        "supported": true,
        "subscriptionless": false
      },
      "apiKeys": {
        "supported": true,
        "federated": true,
        "operations": [
          "issue",
          "regenerate",
          "revoke",
          "associate",
          "dissociate"
        ],
        "associationRequiredForInvocation": true,
        "headerName": "apikey"
      },
      "endpoints": [
        "http",
        "typePRODUCTION",
        "typeSANDBOX"
      ],
      "endpointSecurity": [
        "basicAuth"
      ],
      "tryout": []
    }
  }
}
